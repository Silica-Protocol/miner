# Miner Configuration

# Oracle Configuration
CHERT_ORACLE_URL=http://localhost:8765
CHERT_ORACLE_TIMEOUT_SECS=30

# BOINC Configuration  
CHERT_BOINC_INSTALL_DIR=/tmp/chert_miner_boinc
CHERT_BOINC_DATA_DIR=/tmp/chert_miner_boinc/data
CHERT_BOINC_LOG_FILE=/tmp/chert_miner_boinc/boinc_output.log

# Miner Configuration
CHERT_MINER_USER_ID=miner_001
CHERT_MINER_MODE=traditional

# Work Allocation Configuration
# Enable NUW (Network Utility Work) on CPU - earns fee discounts
CHERT_NUW_ON_CPU=true
# Enable BOINC scientific computing on GPU
CHERT_BOINC_ON_GPU=true
# Percentage of CPU cores to allocate to NUW (0-100)
CHERT_NUW_CPU_PERCENTAGE=25
# Percentage of GPU resources to allocate to BOINC (0-100)
CHERT_BOINC_GPU_PERCENTAGE=75
# Enable on-demand NUW tasks
CHERT_NUW_ON_DEMAND=true
# Minimum NUW difficulty threshold to accept
CHERT_MIN_NUW_DIFFICULTY=1000
# Maximum concurrent BOINC tasks
CHERT_MAX_BOINC_TASKS=2
# Auto-detect hardware capabilities on startup
CHERT_AUTO_DETECT_HARDWARE=true

# Security Configuration
CHERT_REQUIRE_HTTPS=true
CHERT_VERIFY_CERTIFICATES=true
CHERT_RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Development/Debug (set to false for production)
CHERT_DEBUG_MODE=false
CHERT_VERBOSE_LOGGING=false